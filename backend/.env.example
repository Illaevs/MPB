YANDEX_TOKEN=
YANDEX_ROOT_PATH=/mnt/netdisk/CRM

# Auth settings
SECRET_KEY=replace-with-a-random-64-byte-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# External providers
DADATA_TOKEN=
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=https://for-apps.ru/oauth/yandex/callback
YANDEX_OAUTH_SCOPES=mail:imap_ro mail:smtp

# Mail sync
MAIL_POLL_INTERVAL_SECONDS=60

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/mnt/netdisk/CRM
UPLOAD_TMP_DIR=
UPLOAD_TMP_MAX_BYTES=524288000
UPLOAD_TMP_TTL_HOURS=24
