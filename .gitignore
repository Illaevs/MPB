# ============================================================
# Secrets / credentials
# ============================================================
.env
.env.*
!.env.example
!backend/.env.example
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
*.pem
*.key
credentials.*

# ============================================================
# Python
# ============================================================
venv/
.venv/
.venvs/
__pycache__/
*.pyc
*.pyo
*.pyd

# ============================================================
# Databases (никогда не должны попадать в публичный репо)
# ============================================================
*.db
*.sqlite
*.sqlite3
test_portal/*.db
test_portal/*.db-*

# ============================================================
# Backups / generated dumps
# ============================================================
backups/
_backups*/
_eb_v2_bak/
codepatch*/
storage*.tgz
*.tgz
*.tar
*.tar.gz
*.zip

# ============================================================
# Runtime storage / uploads / generated static
# ============================================================
storage/
backend/static/
backend/storage/
backend/tmp_uploads/
backend/uploads/
tmp_uploads/
uploads/

# ============================================================
# Frontend deps / build
# ============================================================
node_modules/
frontend/dist/
frontend/dist.*/

# ============================================================
# test_portal runtime
# ============================================================
test_portal/static/
test_portal/storage/
test_portal/tmp_uploads/
test_portal/assets/

# ============================================================
# OS / IDE
# ============================================================
.DS_Store
.idea/
.vscode/
.vscode/sftp.json

# ============================================================
# Dev tooling — Claude / Codex / локальные скрипты разработчика
# ============================================================
.claude/
.codex_deploy/
_make_*.ps1
_prod_pull/
_exports/

# ============================================================
# Временные / debug-файлы и черновики (только root, чтобы не
# зацепить legitimate __tmp/ внутри проектов, если такие появятся)
# ============================================================
/__tmp_*
/tmp_*
/tmp-debug-*
/_smoke_*.py
/AUDIT_REPORT.md
/akt_*.html

# SQL-черновики в корне (миграции лежат в backend/, их не трогаем)
/alter_*.sql
/assign_*.sql
/update_*.sql
/uuid_*.sql

# Прочие временные документы
/tmp_*.docx
/tmp-debug-*.docx
/tmp-debug-*.xml

# Логи в корне
*.log
